# Backend SMTP configuration (used by server/index.js)
# In production set these as Cloud Run environment variables.
# In local dev, copy this file to .env and fill in SMTP_PASSWORD.

SMTP_HOST=mail.geonyxgroup.com
SMTP_PORT=465
SMTP_USER=office@geonyxgroup.com
SMTP_PASSWORD=
MAIL_TO=office@geonyxgroup.com

# Backend port (do not change unless you also update nginx.conf and vite.config.ts)
PORT=3001
